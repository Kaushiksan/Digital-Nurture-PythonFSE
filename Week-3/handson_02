<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Responsive Student Portal</title>

    <link
        rel="stylesheet"
        href="styles.css"
    >

</head>

<body>

    <!-- =====================================
         HEADER
    ====================================== -->

    <header>

        <h1 class="site-title">
            Student Portal
        </h1>

        <div class="menu-placeholder">
            Menu
        </div>

        <nav>

            <a href="#hero">
                Home
            </a>

            <a href="#courses">
                Courses
            </a>

            <a href="#profile">
                Profile
            </a>

            <a href="#grades">
                Grades
            </a>

        </nav>

    </header>


    <!-- =====================================
         MAIN CONTENT
    ====================================== -->

    <main>

        <!-- HERO SECTION -->

        <section id="hero">

            <h2>
                Welcome to the Student Portal
            </h2>

            <p>
                Manage your courses and academic
                information from one place.
            </p>

            <button type="button">
                Explore Courses
            </button>

        </section>


        <!-- =====================================
             STUDENT STATS
        ====================================== -->

        <section class="stats-bar">

            <div class="stat-item">

                <strong>
                    3
                </strong>

                <span>
                    Courses Enrolled
                </span>

            </div>


            <div class="stat-item">

                <strong>
                    3.8
                </strong>

                <span>
                    GPA
                </span>

            </div>


            <div class="stat-item">

                <strong>
                    6
                </strong>

                <span>
                    Semester
                </span>

            </div>

        </section>


        <!-- =====================================
             COURSES
        ====================================== -->

        <section id="courses">

            <h2>
                My Courses
            </h2>

            <div class="course-grid">

                <article class="course-card">

                    <h3>
                        Python Programming
                    </h3>

                    <p>
                        Learn Python fundamentals,
                        programming concepts and
                        problem solving.
                    </p>

                    <span>
                        4 Credits
                    </span>

                </article>


                <article class="course-card">

                    <h3>
                        Database Management
                    </h3>

                    <p>
                        Learn SQL, database design
                        and data management.
                    </p>

                    <span>
                        3 Credits
                    </span>

                </article>


                <article class="course-card">

                    <h3>
                        Web Development
                    </h3>

                    <p>
                        Learn HTML, CSS and modern
                        frontend development.
                    </p>

                    <span>
                        4 Credits
                    </span>

                </article>


                <article class="course-card">

                    <h3>
                        Data Structures
                    </h3>

                    <p>
                        Learn arrays, linked lists,
                        stacks, queues and algorithms.
                    </p>

                    <span>
                        4 Credits
                    </span>

                </article>


                <article class="course-card">

                    <h3>
                        Computer Networks
                    </h3>

                    <p>
                        Learn networking concepts,
                        protocols and communication.
                    </p>

                    <span>
                        3 Credits
                    </span>

                </article>

            </div>

        </section>

    </main>


    <!-- =====================================
         FOOTER
    ====================================== -->

    <footer>

        <p>
            &copy; 2026 Student Portal.
            All rights reserved.
        </p>

    </footer>

</body>

</html>
